#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"
export AQC_G3RS_BINARY="$(command -v g3rs)"
export AQC_SHAKRS_BINARY="$(command -v shakrs)"
original_path="$PATH"
export PATH="$repo_root/.githooks/bin:$PATH"
if [ -x ".githooks/pre-commit.d/g3rs" ]; then
  . ".githooks/pre-commit.d/g3rs"
else
  echo "Missing executable .githooks/pre-commit.d/g3rs" >&2
  exit 1
fi
#!/bin/sh

# Shackles managed hook chain: shakrs
repo="$(git rev-parse --show-toplevel)"
fragment="$repo/.githooks/pre-commit.d/shakrs"
if [ ! -x "$fragment" ]; then
  echo "Shackles hook fragment is missing or not executable: $fragment" >&2
  exit 1
fi
. "$fragment"
export PATH="$original_path"
unset AQC_G3RS_BINARY AQC_SHAKRS_BINARY
