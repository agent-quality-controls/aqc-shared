#!/bin/sh
set -eu
repo="$(git rev-parse --show-toplevel)"
staged_paths="$(mktemp)"
workspaces="$(mktemp)"
sorted_workspaces="$(mktemp)"
snapshot="$(mktemp -d)"
rmdir "$snapshot"
snapshot_ready=false

cleanup() {
  rm -f "$staged_paths" "$workspaces" "$sorted_workspaces"
  if [ "$snapshot_ready" = true ]; then
    git -C "$repo" worktree remove --force "$snapshot" >/dev/null 2>&1 || {
      rm -rf "$snapshot"
      git -C "$repo" worktree prune
    }
  fi
}
trap cleanup EXIT

run_check() {
  output="$(mktemp)"
  if "$@" >"$output"; then
    rm -f "$output"
    return 0
  else
    status=$?
    cat "$output" >&2
    rm -f "$output"
    return "$status"
  fi
}

run_check 'gitleaks' 'git' '--pre-commit' '--staged' '--no-banner' '--log-level' 'error' '--redact=100' '--report-format' 'json' '--report-path' '-' "$repo"
commit_index="${GIT_INDEX_FILE-}"
unset GIT_DIR GIT_INDEX_FILE GIT_PREFIX GIT_WORK_TREE

index_git() {
  if [ -n "$commit_index" ]; then
    GIT_INDEX_FILE="$commit_index" git -C "$repo" "$@"
  else
    git -C "$repo" "$@"
  fi
}

is_workspace_file() {
  case "$(basename "$1")" in
    *.rs|Cargo.toml|shakrs.json|clippy.toml|deny.toml|rust-toolchain.toml|rustfmt.toml|.rustfmt.toml)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

if git -C "$repo" rev-parse --verify -q HEAD >/dev/null; then
  has_head=true
else
  status=$?
  if [ "$status" -eq 1 ]; then
    has_head=false
  else
    echo "Shackles could not inspect Git HEAD" >&2
    exit "$status"
  fi
fi

if index_tree="$(index_git write-tree)"; then
  :
else
  status=$?
  echo "Shackles could not materialize the staged tree" >&2
  exit "$status"
fi
if [ "$has_head" = true ]; then
  snapshot_commit="$(printf 'Shackles staged validation\n' | GIT_AUTHOR_NAME=Shackles GIT_AUTHOR_EMAIL=shackles@invalid GIT_AUTHOR_DATE='1970-01-01T00:00:00Z' GIT_COMMITTER_NAME=Shackles GIT_COMMITTER_EMAIL=shackles@invalid GIT_COMMITTER_DATE='1970-01-01T00:00:00Z' git -C "$repo" commit-tree "$index_tree" -p HEAD)"
else
  snapshot_commit="$(printf 'Shackles staged validation\n' | GIT_AUTHOR_NAME=Shackles GIT_AUTHOR_EMAIL=shackles@invalid GIT_AUTHOR_DATE='1970-01-01T00:00:00Z' GIT_COMMITTER_NAME=Shackles GIT_COMMITTER_EMAIL=shackles@invalid GIT_COMMITTER_DATE='1970-01-01T00:00:00Z' git -C "$repo" commit-tree "$index_tree")"
fi
git -C "$repo" worktree add --quiet --detach "$snapshot" "$snapshot_commit"
snapshot_ready=true
run_check 'shakrs' 'validate' repo --path "$snapshot"

probe_index_path() {
  probe_path="$1"
  if index_git ls-files --cached --error-unmatch -- "$probe_path" >/dev/null 2>&1; then
    return 0
  else
    status=$?
    [ "$status" -eq 1 ] && return 1
    echo "Shackles could not inspect staged marker: $probe_path" >&2
    return "$status"
  fi
}

probe_head_path() {
  probe_path="$1"
  [ "$has_head" = false ] && return 1
  if head_paths="$(git -C "$repo" ls-tree -r --name-only HEAD -- "$probe_path")"; then
    [ "$head_paths" = "$probe_path" ]
  else
    status=$?
    echo "Shackles could not inspect committed marker: $probe_path" >&2
    return "$status"
  fi
}

marker_path_for() {
  marker_dir_rel="$1"
  marker_name="$2"
  if [ -n "$marker_dir_rel" ]; then
    printf '%s/%s\n' "$marker_dir_rel" "$marker_name"
  else
    printf '%s\n' "$marker_name"
  fi
}

marker_pair_exists() {
  marker_dir_rel="$1"
  primary_path="$(marker_path_for "$marker_dir_rel" Cargo.toml)"
  config_path="$(marker_path_for "$marker_dir_rel" shakrs.json)"

  if probe_index_path "$primary_path"; then
    index_primary=true
  else
    status=$?
    [ "$status" -ne 1 ] && return "$status"
    index_primary=false
  fi

  if probe_index_path "$config_path"; then
    index_config=true
  else
    status=$?
    [ "$status" -ne 1 ] && return "$status"
    index_config=false
  fi

  if [ "$index_primary" = true ] && [ "$index_config" = true ]; then
    return 0
  fi
  if [ "$index_primary" = false ] && [ "$index_config" = false ]; then
    return 1
  fi
  [ "$has_head" = false ] && return 1

  if probe_head_path "$primary_path"; then
    :
  else
    status=$?
    [ "$status" -eq 1 ] && return 1
    return "$status"
  fi
  probe_head_path "$config_path"
}

is_fixture_workspace() {
  candidate_rel="$1"
  [ -z "$candidate_rel" ] && return 1
  fixture_parent="$(dirname "$candidate_rel")"
  [ "$fixture_parent" = . ] && fixture_parent=""
  while :; do
    if probe_index_path "${fixture_parent:+$fixture_parent/}fixture.toml"; then
      return 0
    else
      status=$?
      [ "$status" -ne 1 ] && return "$status"
    fi
    [ -z "$fixture_parent" ] && return 1
    fixture_next="$(dirname "$fixture_parent")"
    [ "$fixture_next" = . ] && fixture_next=""
    [ "$fixture_next" = "$fixture_parent" ] && return 1
    fixture_parent="$fixture_next"
  done
}

record_workspace_for_path() {
  rel="$1"
  dir_rel="$(dirname "$rel")"
  [ "$dir_rel" = . ] && dir_rel=""
  while :; do
    if marker_pair_exists "$dir_rel"; then
      if is_fixture_workspace "$dir_rel"; then
        return 0
      else
        status=$?
        [ "$status" -ne 1 ] && return "$status"
      fi
      if [ -n "$dir_rel" ]; then
        printf '%s/%s\n' "$repo" "$dir_rel" >> "$workspaces"
      else
        printf '%s\n' "$repo" >> "$workspaces"
      fi
      return 0
    else
      status=$?
      [ "$status" -ne 1 ] && return "$status"
    fi
    [ -z "$dir_rel" ] && return 0
    parent="$(dirname "$dir_rel")"
    [ "$parent" = . ] && parent=""
    [ "$parent" = "$dir_rel" ] && return 0
    dir_rel="$parent"
  done
}

if index_git -c core.quotePath=false diff --cached --name-only --no-renames --diff-filter=ACDM > "$staged_paths"; then
  :
else
  status=$?
  echo "Shackles could not read staged paths" >&2
  exit "$status"
fi

while IFS= read -r rel; do
  case "$rel" in
    \"*)
      printf '%s\n' "Shackles cannot safely route quoted Git path: $rel" >&2
      exit 1
      ;;
  esac
  if is_workspace_file "$rel"; then
    record_workspace_for_path "$rel"
  fi
done < "$staged_paths"

if LC_ALL=C sort -u "$workspaces" > "$sorted_workspaces"; then
  :
else
  status=$?
  echo "Shackles could not sort workspace paths" >&2
  exit "$status"
fi

while IFS= read -r workspace; do
  if [ "$workspace" = "$repo" ]; then
    snapshot_workspace="$snapshot"
  else
    snapshot_workspace="$snapshot/${workspace#"$repo"/}"
  fi
  run_check 'shakrs' 'validate' workspace --path "$snapshot_workspace"
done < "$sorted_workspaces"
