{
  "policies": {
    "defaultEnabled": true,
    "overrides": {
      "shakrs-cargo-policy": { "enabled": true, "params": { "inheritWorkspaceLints": false } },
      "shakrs-clippy-strict-policy": { "enabled": true, "params": { "targetWorkspace": false } },
      "shakrs-rustc-strict-policy": { "enabled": true, "params": { "targetWorkspace": false } },
      "shakrs-rustfmt-policy": { "enabled": true, "params": { "inWorkspacePackage": false } },
      "shakrs-toolchain-policy": { "enabled": true, "params": { "inWorkspacePackage": false } }
    }
  },
  "version": 1,
  "waivers": [
    {
      "subject": "Cargo.toml",
      "key": "[lints.clippy].trivially_copy_pass_by_ref",
      "selector": null,
      "reason": "Public enum accessors keep borrowed receivers for API consistency across toolchain value types."
    }
  ]
}
